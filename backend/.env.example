APP_NAME=QashFlow Inference API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
CORS_ORIGINS=http://localhost:3000

# Optional: absolute or relative paths
MODEL_CHECKPOINT_PATH=../saved_models/model.pth
SCALER_PATH=../saved_models/scaler.pkl

# If true, API runs even when checkpoint is missing by using deterministic fallback predictions.
ALLOW_FALLBACK_PREDICTOR=true
